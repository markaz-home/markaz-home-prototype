# =============================================================================
# MARKAZ Home — environment contract (Week 1)
# Copy to `.env` at the repo root: `cp .env.example .env`
# `.env` is git-ignored and must NEVER be committed.
# Values below are SAFE LOCAL DEFAULTS produced by `pnpm supabase:start`.
# Run `pnpm supabase:status` to print the local anon/service keys for your machine.
# =============================================================================

# --- Public application URLs (safe to expose to the browser) ------------------
# Customer/public web app and the SEPARATE admin app run on different hosts.
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# --- Supabase public client (safe to expose to the browser) -------------------
# Local stack defaults. The anon key is the demo key printed by `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.local-anon-key-replace-with-supabase-status

# --- Database connections (SERVER ONLY — never exposed to any client) ---------
# DATABASE_URL: pooled/app connection used by tRPC customer-scoped queries.
# DIRECT_DATABASE_URL: direct connection for migrations & admin/worker ops
#   (in production Realtime + migrations connect direct to RDS, never via a pooler).
# Local default points both at the Supabase CLI Postgres.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Supabase service role (SERVER ONLY — privileged, NEVER in client bundle) -
# Used only for migrations/seed/trusted server ops + demo provisioning. NEVER for
# customer-scoped requests. IMPORTANT: the GoTrue Admin API (used by `pnpm db:setup`)
# requires the legacy `service_role` JWT — copy the `SERVICE_ROLE_KEY` (eyJ… JWT)
# from `pnpm supabase:status`, NOT the newer `sb_secret_…` Secret key.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.local-service-role-key-replace-with-supabase-status

# --- Conditional demo-auth fallback (disabled by default — see ADR-0007) ------
# DEMO_ENVIRONMENT: "local" | "staging" | "production". Fallback only allowed off-prod.
# DEMO_AUTH_FALLBACK: "true" enables the allow-listed one-click demo sign-in.
# DEMO_AUTH_ALLOWLIST: comma-separated demo emails permitted to use the fallback.
DEMO_ENVIRONMENT=local
DEMO_AUTH_FALLBACK=false
DEMO_AUTH_ALLOWLIST=customer-a@markaz.demo,customer-b@markaz.demo,admin@markaz.demo

# --- Optional admin bootstrap (SERVER ONLY) ------------------------------------
# Customers sign up through the app — nothing is seeded. To create the ONE admin
# (admins cannot self-sign-up), set both vars below and run `pnpm db:setup`; with
# them unset, `pnpm db:setup` is a no-op. Never commit a real password.
# BOOTSTRAP_ADMIN_EMAIL=you@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-strong

# --- UAE PASS Staging (POC — SERVER ONLY, never NEXT_PUBLIC_) ------------------
# UAE PASS is wired as a Supabase custom OAuth provider (custom:uae-pass) and is an
# OPTIONAL sign-in method. `simulated` (the default / unset) keeps it OFF so local
# dev, tests, and CI need no UAE PASS network access or credentials.
# To enable the real STAGING login: set UAE_PASS_MODE=staging + the sandbox creds,
# then `pnpm db:setup-uae-pass` to register the provider with Supabase Auth.
# Endpoint hosts are allow-listed in code (stg-id.uaepass.ae) — never set here.
# See docs/integrations/uae-pass-staging-poc.md. Production endpoints are OUT OF SCOPE.
UAE_PASS_MODE=simulated
# UAE_PASS_CLIENT_ID=sandbox_stage
# UAE_PASS_CLIENT_SECRET=sandbox_stage
# Required only when intentionally configuring a hosted Supabase Auth tenant:
# UAE_PASS_ALLOW_REMOTE_SETUP=true

# --- Internationalisation (safe to expose to the browser) ---------------------
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ar
